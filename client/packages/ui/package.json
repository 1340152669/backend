{
  "name": "@rbac/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./components": {
      "types": "./src/components.ts",
      "import": "./src/components.ts"
    },
    "./plugin": {
      "types": "./src/plugin.ts",
      "import": "./src/plugin.ts"
    },
    "./*": {
      "types": "./src/*",
      "import": "./src/*"
    }
  },
  "scripts": {
    "test:unit": "vitest run",
    "build": "vite build",
    "prepublishOnly": "vite build"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./components": {
        "types": "./dist/components.d.ts",
        "import": "./dist/components.js"
      },
      "./plugin": {
        "types": "./dist/plugin.d.ts",
        "import": "./dist/plugin.js"
      },
      "./*": {
        "types": "./dist/*.d.ts",
        "import": "./dist/*.js"
      }
    }
  },
  "peerDependencies": {
    "vue": "^3.5.32"
  },
  "dependencies": {
    "lucide-vue-next": "^0.479.0",
    "vue": "^3.5.32",
    "zod": "^4.4.3"
  }
}
